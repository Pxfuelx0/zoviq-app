rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, list: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'yassineharzami19@gmail.com');
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'yassineharzami19@gmail.com');
    }
  }
}
